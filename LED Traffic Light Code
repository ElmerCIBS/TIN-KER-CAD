// C++ code
//
#include <Wire.h>              
#include <LiquidCrystal_I2C.h>
 
LiquidCrystal_I2C lcd(0x20, 16, 2);
const int LED_ROJO = 13;
const int LED_AMARILLO = 12;
const int LED_VERDE = 11;
 
void setup()
{
  pinMode(LED_ROJO,OUTPUT);
  pinMode(LED_AMARILLO,OUTPUT);
  pinMode(LED_VERDE,OUTPUT);
  digitalWrite(LED_ROJO, LOW);
  digitalWrite(LED_AMARILLO, LOW);
  digitalWrite(LED_VERDE, LOW);
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(2,0);
  lcd.print("Semaforo");
  lcd.setCursor(1,1);
  lcd.print("Inteligente");
  delay(2500);
  lcd.clear();
}
 
void loop()
{
  digitalWrite(LED_VERDE, HIGH);
  digitalWrite(LED_AMARILLO, LOW);
  digitalWrite(LED_ROJO, LOW);
  lcd.setCursor(0,0);
  lcd.print("Verde -> Siga");
  for(int tiempo = 5; tiempo > 0; tiempo--){
  	lcd.setCursor(0,1);
    lcd.print("Cuenta Regresiva");
    delay(2500);
    lcd.clear();
    lcd.print(tiempo);
    delay(2000);
    lcd.clear();
  }
  digitalWrite(LED_VERDE, LOW);
  digitalWrite(LED_AMARILLO, HIGH);
  digitalWrite(LED_ROJO, LOW);
  lcd.setCursor(0,0);
  lcd.print("Amarillo -> Cuidado");
  for(int tiempo = 5; tiempo > 0; tiempo--){
  	lcd.setCursor(0,1);
    lcd.print("Cuenta Regresiva");
    delay(2000);
    lcd.clear();
    lcd.print(tiempo);
    delay(1000);
    lcd.clear();
  }
  digitalWrite(LED_VERDE, LOW);
  digitalWrite(LED_AMARILLO, LOW);
  digitalWrite(LED_ROJO, HIGH);
  lcd.setCursor(0,0);
  lcd.print("Rojo -> Alto");
  for(int tiempo = 5; tiempo > 0; tiempo--){
  	lcd.setCursor(0,1);
    lcd.print("Cuenta Regresiva");
    delay(2500);
    lcd.clear();
    lcd.print(tiempo);
    delay(2000);
    lcd.clear();
  }
  lcd.clear();
}
